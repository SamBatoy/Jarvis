# ─── Supabase (required) ────────────────────────────────────────────────────
# Project Settings → API in your Supabase project.
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# ─── LLM provider (required for chat) ──────────────────────────────────────
# Swappable in one place: change LLM_PROVIDER + LLM_MODEL to switch models.
# Default: Groq running Llama 3.3 70B (strong tool-calling, fast, free tier).
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=

# Only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# ─── Web search (optional, for learning-path resources) ────────────────────
# Without this, learning paths still generate but resources are left empty
# with a note, instead of inventing links.
TAVILY_API_KEY=

# ─── App ────────────────────────────────────────────────────────────────────
# Single fixed timezone (this is a single-user app) used for "today" and all
# scaffolding/scheduling date math.
APP_TIMEZONE=America/Los_Angeles

# ─── Cron (required) ────────────────────────────────────────────────────────
# Protects api/cron/archive-overdue.js so only Vercel's scheduler can trigger
# it. Generate any high-entropy random string, e.g.:
#   node -e "console.log(require('node:crypto').randomBytes(24).toString('base64url'))"
CRON_SECRET=

# Local dev only (not used in the deployed app): port for `npm run dev:api`,
# the lightweight stand-in server for Vercel functions. Defaults to 3001.
# DEV_API_PORT=3001

# ─── Google (Gmail, required for Phase 5) ───────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials (OAuth client).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match one of the "Authorized redirect URIs" on that OAuth
# client. Differs per environment: http://localhost:3001/api/auth/google/callback
# locally, https://<your-domain>/api/auth/google/callback in production.
GOOGLE_REDIRECT_URI=

# Where the OAuth callback redirects back to after connecting — the
# frontend's own origin, not the API server's. Differs per environment:
# http://localhost:5175 locally, https://<your-domain> in production.
APP_BASE_URL=

# From Supabase → Project Settings → API → "service_role" secret (NOT the
# anon key). Only used server-side, only to touch the oauth_connections
# table — see supabase/migrations/007_phase5_google_integration.sql for why
# this table needs real service-role access instead of the anon-access
# pattern used everywhere else in this app.
SUPABASE_SERVICE_ROLE_KEY=

# Encrypts OAuth refresh/access tokens at the application layer before they
# ever reach Postgres, independent of Supabase's own disk-level encryption.
# Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
TOKEN_ENCRYPTION_KEY=
